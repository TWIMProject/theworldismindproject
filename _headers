# Audios privados · solo accesibles con la URL exacta del QR
# Evitar indexación en buscadores (refuerza el meta noindex de la página)
/audios-firmados/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: private, max-age=0, no-cache

# Descargas de productos digitales · solo accesibles con la URL exacta tras compra
/descargas/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: private, max-age=0, no-cache
