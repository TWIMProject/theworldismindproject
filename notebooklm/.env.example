# ─── TWIM NotebookLM Integration ───────────────────────────────
# Copia este archivo a .env y ajusta los valores

# Título del notebook en NotebookLM
TWIM_NOTEBOOK_TITLE=TWIM Project - Insights Psicología

# Idioma para todos los artefactos generados
TWIM_LANGUAGE=es

# ─── Instrucciones personalizadas por artefacto ────────────────
# (Opcional: si no se definen, se usan los valores por defecto)

# TWIM_AUDIO_INSTRUCTIONS=Genera una conversación en español...
# TWIM_VIDEO_INSTRUCTIONS=Crea un vídeo explicativo en español...
# TWIM_REPORT_INSTRUCTIONS=Elabora un informe profesional...
# TWIM_QUIZ_INSTRUCTIONS=Genera preguntas en español...
# TWIM_FLASHCARDS_INSTRUCTIONS=Crea tarjetas de estudio...
# TWIM_INFOGRAPHIC_INSTRUCTIONS=Diseña una infografía...
# TWIM_SLIDES_INSTRUCTIONS=Crea una presentación profesional...

# ─── Autenticación CI/CD ───────────────────────────────────────
# Contenido JSON del storage state (alternativa al login por navegador)
# NOTEBOOKLM_AUTH_JSON={"cookies": [...]}
