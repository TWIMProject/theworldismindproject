# TWIM NotebookLM Integration - Variables de entorno opcionales
# Copia este archivo a .env y ajusta los valores

# Título del notebook en NotebookLM
TWIM_NOTEBOOK_TITLE=TWIM Project - Insights Psicología

# Idioma para el audio generado
TWIM_AUDIO_LANGUAGE=es

# Instrucciones personalizadas para el podcast
TWIM_AUDIO_INSTRUCTIONS=Genera una conversación en español entre dos presentadores sobre psicología aplicada, ansiedad laboral y bienestar emocional. El tono debe ser cercano, profesional y accesible.

# Para CI/CD: contenido JSON del storage state de NotebookLM (alternativa al login por navegador)
# NOTEBOOKLM_AUTH_JSON={"cookies": [...]}
